// Power Docs — Entity Relationship Model
// Version: 1.2.7 | Date: 2026-03-11

Enum post_status {
  publish [note: '已發佈']
  draft [note: '草稿']
  pending [note: '送交審閱']
  private [note: '私密']
  trash [note: '已刪除']
}

Enum editor_type {
  power_editor [note: 'Power Editor (BlockNote)']
  elementor [note: 'Elementor 編輯器']
  empty [note: '空字串，知識庫首頁預設版型']
}

Enum need_access_type {
  yes [note: '需要購買授權才能觀看']
  no [note: '免費公開']
}

Enum product_type {
  simple [note: '簡單商品']
  grouped [note: '組合商品']
  external [note: '外部商品']
  variable [note: '可變商品']
  variation [note: '商品變體']
  subscription [note: '簡易訂閱']
  variable_subscription [note: '可變訂閱']
  subscription_variation [note: '訂閱變體']
}

Enum limit_type {
  unlimited [note: '永久']
  fixed [note: '固定天數']
  follow_subscription [note: '跟隨訂閱']
}

// ==================== WordPress 核心表 ====================

Table wp_posts {
  ID bigint [pk, increment, note: '文章 ID']
  post_author bigint [note: '作者 ID']
  post_date datetime [note: '發佈日期']
  post_date_gmt datetime [note: '發佈日期 (GMT)']
  post_content longtext [note: '內容 HTML']
  post_title text [note: '標題']
  post_status varchar [note: '狀態']
  post_name varchar [note: '網址別名 (slug)']
  post_parent bigint [default: 0, note: '父文章 ID，0=根層級']
  post_type varchar [note: '文章類型']
  menu_order int [default: 0, note: '排序順序']
  post_modified datetime [note: '修改日期']

  indexes {
    (post_type, post_status, post_parent) [name: 'type_status_parent']
    (post_parent) [name: 'post_parent']
  }

  Note: '''
    Power Docs 使用 post_type = "pd_doc" 的文章。
    階層結構：知識庫(root, parent=0) → 章節(depth=1) → 單元(depth=2)
  '''
}

Table wp_postmeta {
  meta_id bigint [pk, increment]
  post_id bigint [ref: > wp_posts.ID, note: '對應文章 ID']
  meta_key varchar [note: 'Meta 鍵名']
  meta_value longtext [note: 'Meta 值']

  indexes {
    (post_id, meta_key) [name: 'post_id_meta_key']
  }

  Note: '''
    Power Docs 使用的 meta_key：
    - editor: 編輯器類型 (power-editor / elementor / 空字串)
    - bg_images: 背景圖 attachment ID (僅根知識庫)
    - need_access: 是否需要授權 (yes / no, 僅根知識庫)
    - pd_keywords: 搜尋關鍵字 JSON (僅根知識庫)
    - pd_keywords_label: 關鍵字標籤文字 (僅根知識庫)
    - unauthorized_redirect_url: 未授權跳轉網址 (僅根知識庫)

    WooCommerce 商品使用的 meta_key：
    - bound_docs_data: 綁定的知識庫授權資料 JSON
  '''
}

Table wp_users {
  ID bigint [pk, increment, note: '用戶 ID']
  user_login varchar [unique, note: '帳號']
  user_email varchar [note: '電子信箱']
  user_nicename varchar [note: '別名']
  display_name varchar [note: '顯示名稱']
  user_registered datetime [note: '註冊日期']

  indexes {
    (user_login) [unique, name: 'user_login_key']
    (user_email) [name: 'user_email']
  }

  Note: '''
    WordPress 用戶表。
    Power Docs 透過 ph_access_itemmeta 管理用戶的知識庫存取權限。
  '''
}

Table wp_usermeta {
  umeta_id bigint [pk, increment]
  user_id bigint [ref: > wp_users.ID, note: '對應用戶 ID']
  meta_key varchar [note: 'Meta 鍵名']
  meta_value longtext [note: 'Meta 值']

  indexes {
    (user_id, meta_key) [name: 'user_id_meta_key']
  }

  Note: '''WordPress 用戶 meta 表'''
}

// ==================== Powerhouse 擴充表 ====================

Table wp_ph_access_itemmeta {
  meta_id bigint [pk, increment]
  post_id bigint [ref: > wp_posts.ID, note: '知識庫根文章 ID']
  user_id bigint [ref: > wp_users.ID, note: '用戶 ID']
  meta_key varchar [note: '固定為 expire_date']
  meta_value longtext [note: '到期日期字串，空字串=永久']

  indexes {
    (post_id, user_id, meta_key) [name: 'post_user_key']
    (user_id, meta_key) [name: 'user_key']
  }

  Note: '''
    Powerhouse 提供的存取權限表。
    Power Docs 用此表記錄用戶對知識庫的存取權限。
    meta_key 固定為 "expire_date"，meta_value 為到期日期。
    空字串或未來日期 = 有效；過去日期 = 已過期。
  '''
}

// ==================== WooCommerce 表 ====================

Table wp_wc_orders {
  id bigint [pk, increment, note: '訂單 ID']
  customer_id bigint [ref: > wp_users.ID, note: '顧客 ID，0=訪客']
  status varchar [note: '訂單狀態']
  date_created_gmt datetime [note: '建立日期']

  Note: '''
    WooCommerce 訂單表。
    Power Docs 監聽 woocommerce_order_status_completed 事件，
    訂單完成時自動授權知識庫存取權限。
  '''
}

// ==================== References ====================

// 知識庫階層關係（自引用）
Ref: wp_posts.post_parent > wp_posts.ID

// 訂單完成 → 檢查商品 bound_docs_data → 寫入 ph_access_itemmeta
// (邏輯引用，非外鍵)
Ref: wp_wc_orders.customer_id > wp_users.ID
